# User specific aliases and functions

# Source this file in your ~/.bashrc. 

# Set HPC_SOFTWARE to folder containing all software (jorek, libs, this code, etc.)
export HPC_SOFTWARE=/pitagora/home/userexternal/mquantri/software
# Set HPC_DATA to folder containing all data (jorek_data, xtor_data, mastu_equilibria, etc.)
export HPC_DATA=/pitagora_scratch/userexternal/mquantri


export JOREK_MODELS=$HPC_DATA/jorek_models
export JOREK_DATA=$HPC_DATA/jorek_data
export XTOR_DATA=$HPC_DATA/xtor_data
export MASTU=$HPC_DATA/mastu_equilibria
export JX_DATA=$HPC_DATA/jorek_xtor_benchmark_data

export XTOR=$HPC_SOFTWARE/xtor_k
export JOREK=$HPC_SOFTWARE/jorek
export JOREK_UTIL=$JOREK/util

export YP_CODE=$HPC_SOFTWARE/York-Project-Code/application/
export JOREK_TOOLS=$YP_CODE/jorek_tools
export CHEASE_TOOLS=$YP_CODE/chease_tools
export XTOR_TOOLS=$YP_CODE/xtor_tools

alias sq="squeue --user=mquantri"

source $YP_CODE/bashrc/generic_aliases

# Disable "smart" tab completion (stops it from escaping $ symbols
shopt -u progcomp 

